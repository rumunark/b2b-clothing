{
  "expo": {
    "name": "b2b-clothing-mobile",
    "slug": "b2b-clothing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.b2bclothing",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": true,
          "merchantIdentifier": "merchant.com.b2bclothing"
        }
      ],
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "3fe20117-6672-44d9-aa7c-128c97f5e78e"
      }
    },
    "owner": "b2b-collective"
  }
}
